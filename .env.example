# LLM Provider — chọn một trong: anthropic | openai | groq | mistral | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI-compatible (OpenAI, Groq, Together AI, Mistral, Ollama...)
OPENAI_API_KEY=
OPENAI_BASE_URL=        # để trống = OpenAI; điền endpoint khác để dùng provider tương thích

# Google Gemini
GEMINI_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Microsoft Teams
TEAMS_WEBHOOK_URL=      # Incoming Webhook URL của channel Teams

# Slack (Phase 5 Ngày 24 — Incoming Webhook, không OAuth)
SLACK_WEBHOOK_URL=      # https://hooks.slack.com/services/...

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

# Output channels (comma-separated: telegram,teams,email,slack)
# Chỉ dùng khi project không có config riêng trong DB
OUTPUT_CHANNELS=telegram

# Webhook Signature Secrets (Phase 5 Ngày 24 — HMAC-SHA256)
# Nếu set → verify bắt buộc; nếu bỏ trống → pass-through (backward compat)
PROMETHEUS_WEBHOOK_SECRET=
GRAFANA_WEBHOOK_SECRET=
ALERTMANAGER_WEBHOOK_SECRET=
SENTRY_WEBHOOK_SECRET=

# Langfuse (Phase 2 — Observability)
# Để trống = không gửi Langfuse (SQLite trace vẫn chạy bình thường)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com   # hoặc self-hosted URL

# Database
DB_PATH=data/investigation.db
