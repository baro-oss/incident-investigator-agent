# LLM Provider — chọn một trong: anthropic | openai | groq | mistral | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI-compatible (OpenAI, Groq, Together AI, Mistral, Ollama...)
OPENAI_API_KEY=
OPENAI_BASE_URL=        # để trống = OpenAI; điền endpoint khác để dùng provider tương thích

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Microsoft Teams
TEAMS_WEBHOOK_URL=      # Incoming Webhook URL của channel Teams

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

# Output channels (comma-separated: telegram,teams,email)
# Chỉ dùng khi project không có config riêng trong DB
OUTPUT_CHANNELS=telegram

# Database
DB_PATH=data/investigation.db
