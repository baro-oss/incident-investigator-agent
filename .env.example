# LLM Provider — chọn một trong: anthropic | openai | groq | mistral | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI-compatible (OpenAI, Groq, Together AI, Mistral, Ollama...)
OPENAI_API_KEY=
OPENAI_BASE_URL=        # để trống = OpenAI; điền endpoint khác để dùng provider tương thích

# Google Gemini
GEMINI_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Microsoft Teams
TEAMS_WEBHOOK_URL=      # Incoming Webhook URL của channel Teams

# Slack (Phase 5 Ngày 24 — Incoming Webhook, không OAuth)
SLACK_WEBHOOK_URL=      # https://hooks.slack.com/services/...

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

# Output channels (comma-separated: telegram,teams,email,slack)
# Chỉ dùng khi project không có config riêng trong DB
OUTPUT_CHANNELS=telegram

# Webhook Signature Secrets (Phase 5 Ngày 24 — HMAC-SHA256)
# Nếu set → verify bắt buộc; nếu bỏ trống → pass-through (backward compat)
PROMETHEUS_WEBHOOK_SECRET=
GRAFANA_WEBHOOK_SECRET=
ALERTMANAGER_WEBHOOK_SECRET=
SENTRY_WEBHOOK_SECRET=

# Langfuse (Phase 2 — Observability)
# Để trống = không gửi Langfuse (SQLite trace vẫn chạy bình thường)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com   # hoặc self-hosted URL

# Server port (AgentBase hard-wires 8080 — KHÔNG đổi trong prod)
PORT=8080

# App environment: "production" → fail-fast nếu secrets chưa set
# Dev: để trống hoặc "development"
APP_ENV=

# Log format: "json" → JSON một dòng (log aggregator); "text" → human-readable (mặc định)
LOG_FORMAT=

# Database backend — chỉ dùng Postgres
# DB_BACKEND=postgres (bắt buộc)
DB_BACKEND=postgres

# PostgreSQL — bắt buộc
# Tạo DB: docker compose --profile postgres up -d postgres
#          DATABASE_URL=... python data/init_db.py
# DATABASE_URL format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://agent:agent@localhost:5432/investigation

# GreenNode AgentBase — 4 biến này được inject TỰ ĐỘNG bởi platform khi deploy
# KHÔNG set thủ công ở đây — chỉ để reference
# GREENNODE_CLIENT_ID=       # auto-inject by AgentBase
# GREENNODE_CLIENT_SECRET=   # auto-inject by AgentBase
# GREENNODE_AGENT_IDENTITY=  # auto-inject by AgentBase
# GREENNODE_ENDPOINT_URL=    # auto-inject by AgentBase

# Security (Phase 6 Ngày 28 — A2/A4)
# SECRET_KEY: dùng để mã hóa llm_config và auth_config at-rest (Fernet AES-128)
# Để trống = không mã hóa (backward compat — KHÔNG dùng trong prod)
# Tạo key: python3 -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
SECRET_KEY=

# SESSION_SECRET_KEY: ký session cookie (Starlette SessionMiddleware)
# BẮT BUỘC đặt trong prod — để trống = dùng dev fallback (server log sẽ cảnh báo)
# Tạo key: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=

# A4: Cho phép gọi /trigger không cần token (dev only — đặt false trong prod)
ALLOW_ANON_TRIGGER=false

# A3: Giữ trace_events trong bao nhiêu ngày (default 30)
TRACE_RETENTION_DAYS=30

# B3/B4: Reliability (Phase 6 Ngày 29)
# Số investigations tối đa per-project per-hour (default 20)
INVESTIGATION_RATE_LIMIT=20

# Ngày 32: Proactive Monitoring
# Số lần xuất hiện cùng root_cause_type trước khi gửi recurring alert (default 5)
RECURRING_ALERT_THRESHOLD=5

# Ngày 35: SSE backend seam (default: memory = in-process asyncio.Queue)
# Đặt redis để dùng Redis pub/sub khi scale multi-process (cần REDIS_URL)
SSE_BACKEND=memory
REDIS_URL=redis://localhost:6379
